# Servidor Node.js
PORT=3000

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:1667
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_INSTANCE_NAME=minha-instancia
EVOLUTION_SERVER_URL=http://localhost:1667

# Google AI Studio (Gemini)
GEMINI_API_KEY=sua_chave_gemini

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_chave_supabase

# PostgreSQL (Evolution API via Docker)
POSTGRES_USER=evolution
POSTGRES_PASSWORD=altere_esta_senha
POSTGRES_DB=evolution

# Seguranca do webhook
WEBHOOK_SECRET=altere_este_secret
WEBHOOK_URL=http://host.docker.internal:3000/webhook

# Configuracoes do bot
LOG_LEVEL=info
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=512
GEMINI_FALLBACK_MESSAGE=Eita, deu uma instabilidade aqui do meu lado 😅 Tenta me mandar de novo em instantes?
CONTEXT_MESSAGE_LIMIT=10
DEBOUNCE_MS=3000
DEDUP_TTL_MS=86400000
MAX_DAILY_MESSAGES=50
